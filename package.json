{
  "name": "api2app",
  "version": "0.1.0",
  "description": "Generate a React frontend from an OpenAPI file.",
  "type": "module",
  "bin": {
    "api2app": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "lint": "eslint .",
    "smoke": "npm run build && node tests/runGeneratedAppSmokeTest.js",
    "start": "node dist/index.js",
    "test": "npm run build && node tests/runTests.js",
    "check": "npm run lint && npm run test"
  },
  "keywords": [
    "openapi",
    "swagger",
    "react",
    "typescript",
    "frontend-generator",
    "crud"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.0.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.0.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.30.1",
    "typescript": "^5.0.0"
  }
}
