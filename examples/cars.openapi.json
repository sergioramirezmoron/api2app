{
  "openapi": "3.0.0",
  "info": {
    "title": "Cars API",
    "version": "1.0.0"
  },
  "paths": {
    "/cars": {
      "get": {
        "summary": "Get all cars",
        "responses": {
          "200": {
            "description": "List of cars",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Car"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create car",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Car"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Car created"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Car": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "brand": { "type": "string" },
          "model": { "type": "string" },
          "year": { "type": "number" },
          "price": { "type": "number" },
          "fuel": { "type": "string" }
        }
      }
    }
  }
}